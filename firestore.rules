rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Participantes: lectura pública, escritura solo desde servidor autenticado
    match /participantes/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Resultados: solo lectura pública
    match /resultados/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Logs de email: nadie los lee/escribe desde el browser
    match /logs_email/{id} {
      allow read: if false;
      allow write: if false;
    }

    // Todo lo demás: denegado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
