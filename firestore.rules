rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Participantes: lectura pública, escritura desde servidor (API key) o usuario autenticado
    match /participantes/{id} {
      allow read: if true;
      allow write: if true;
    }

    // Resultados: lectura pública, escritura desde servidor
    match /resultados/{id} {
      allow read: if true;
      allow write: if true;
    }

    // Config: lectura/escritura desde servidor (auto-sync)
    match /config/{id} {
      allow read, write: if true;
    }

    // Logs de email: solo desde servidor
    match /logs_email/{id} {
      allow read: if false;
      allow write: if true;
    }

    // Todo lo demás: denegado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
