rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Participantes: lectura y escritura pública (app controla validaciones)
    match /participantes/{id} {
      allow read, write: if true;
    }

    // Resultados: lectura y escritura pública (solo marcadores, sin datos personales)
    match /resultados/{id} {
      allow read, write: if true;
    }

    // Config (sync timestamps): lectura y escritura pública
    match /config/{id} {
      allow read, write: if true;
    }

    // Logs de email: nadie los lee/escribe desde el browser
    match /logs_email/{id} {
      allow read: if false;
      allow write: if false;
    }

    // Todo lo demás: denegado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
